@{
    ViewData["Title"] = "Home Page";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>EventEase Management Company</title>

    
    <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/4.0.0/css/bootstrap.min.css">

  
    <link href="https://fonts.googleapis.com/css2?family=Lato&family=Arimo&display=swap" rel="stylesheet">

    <style>
        body {
            font-family: 'Arimo', sans-serif;
            background-color: #f0fff0; /* fallback light green */
            color: #333;
        }

        .navbar {
            background-color: #7CFC00; /* light green */
        }

        .navbar-brand {
            font-weight: bold;
            color: white;
        }

        .jumbotron {
            position: relative;
            background-image: url('https://source.unsplash.com/1600x900/?nature,green');
            background-size: cover;
            background-position: center;
            color: white;
            padding: 150px 30px;
            overflow: hidden;
        }

            /* Overlay to darken background for better readability */
            .jumbotron::before {
                content: "";
                position: absolute;
                top: 0;
                left: 0;
                width: 100%;
                height: 100%;
                background-color: rgba(0, 0, 0, 0.4); /* dark overlay */
                z-index: 0;
            }

            .jumbotron .container {
                position: relative;
                z-index: 1;
            }

            /* Welcome heading */
            .jumbotron h1 {
                font-size: 3rem;
                font-weight: bold;
                font-family: 'Lato', sans-serif;
                margin-bottom: 20px;
            }

            /* Paragraph text */
            .jumbotron p {
                font-size: 1.5rem;
                font-family: 'Arimo', sans-serif;
                margin-bottom: 40px;
            }

        .btn-azure {
            background-color: #7CFC00;
            color: black; 
            border: none;
            transition: all 0.3s ease;
        }

            /* Button hover effect */
            .btn-azure:hover {
                background-color: #32CD32; /* slightly darker green */
                transform: scale(1.05);
                box-shadow: 0 5px 15px rgba(0,0,0,0.3);
                color: black; 
            }

        .features {
            margin-top: 30px;
        }

        .feature {
            text-align: center;
        }

            .feature img {
                width: 100px;
                height: 100px;
            }

        .btn-group {
            margin-top: 20px;
        }

        /* Razor-safe responsive heading */
        @@media (max-width: 768px) {
            .jumbotron h1 {
                font-size: 2.2rem;
            }

            .jumbotron p {
                font-size: 1.2rem;
            }
        }
    </style>
</head>

<body>
    <nav class="navbar navbar-expand-lg navbar-light">
        <a class="navbar-brand" href="#">Event Management</a>
    </nav>

    <div class="jumbotron text-center">
        <div class="container">
            <h1>Welcome to EventEase!</h1>
            <p>Plan smart. Book fast. Celebrate with ease.</p>

            <div class="btn-group" role="group">
                <a href="/Venue" class="btn btn-azure btn-lg">Venues</a>
                <a href="/Event" class="btn btn-azure btn-lg">Events</a>
                <a href="/Booking" class="btn btn-azure btn-lg">Bookings</a>
            </div>
        </div>
    </div>
</body>
</html>