@model IEnumerable<EventEase.Models.Venue>

@{
    ViewData["Title"] = "Venue List";
}


<link href="https://fonts.googleapis.com/css2?family=Lato&family=Arimo&display=swap" rel="stylesheet">

<style>
    body {
        font-family: 'Arimo', sans-serif;
        background-color: #f0fff0; /* light green background */
        color: #333;
        padding: 20px;
    }

    h1 {
        font-family: 'Lato', sans-serif;
        font-size: 2.5rem;
        margin-bottom: 20px;
        color: #2F4F2F; /* dark green heading */
    }

    table {
        width: 100%;
        border-collapse: collapse;
        background-color: white;
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
    }

    th {
        font-family: 'Lato', sans-serif;
        background-color: #7CFC00; /* light green */
        color: black;
        padding: 10px;
        text-align: left;
    }

    td {
        font-family: 'Arimo', sans-serif;
        padding: 10px;
        border-bottom: 1px solid #ddd;
    }

    tr:hover {
        background-color: #e0ffe0; /* subtle green hover */
    }

    
    .btn-azure {
        display: inline-block;
        padding: 10px 20px;
        margin: 2px;
        background-color: #7CFC00;
        color: black;
        border: none;
        font-family: 'Lato', sans-serif;
        font-weight: bold;
        border-radius: 5px;
        text-decoration: none;
        text-align: center;
        transition: all 0.3s ease;
    }

        .btn-azure:hover {
            background-color: #32CD32; /* slightly darker green */
            color: black;
            transform: scale(1.05);
            box-shadow: 0 5px 15px rgba(0,0,0,0.3);
        }

   
    .create-btn {
        margin-bottom: 15px;
    }

    /* Action buttons inside table */
    .action-btn {
        font-size: 0.9rem;
        padding: 5px 10px;
        margin: 2px;
    }

    /* Razor-safe responsive text */
    @@media (max-width: 768px) {
        h1 {
            font-size: 2rem;
        }

        table, th, td {
            font-size: 0.9rem;
        }

        .btn-azure {
            padding: 8px 15px;
            font-size: 0.9rem;
        }
    }
</style>

<h1>Venues</h1>

<p>
    <a asp-action="Create" class="btn-azure create-btn">Create New</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>@Html.DisplayNameFor(model => model.VenueID)</th>
            <th>@Html.DisplayNameFor(model => model.VenueName)</th>
            <th>@Html.DisplayNameFor(model => model.Location)</th>
            <th>@Html.DisplayNameFor(model => model.Capacity)</th>
            <th>@Html.DisplayNameFor(model => model.ImageUrl)</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@Html.DisplayFor(modelItem => item.VenueID)</td>
                <td>@Html.DisplayFor(modelItem => item.VenueName)</td>
                <td>@Html.DisplayFor(modelItem => item.Location)</td>
                <td>@Html.DisplayFor(modelItem => item.Capacity)</td>
                <td>@Html.DisplayFor(modelItem => item.ImageUrl)</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.VenueID" class="btn-azure action-btn">Edit</a>
                    <a asp-action="Details" asp-route-id="@item.VenueID" class="btn-azure action-btn">Details</a>
                    <a asp-action="Delete" asp-route-id="@item.VenueID" class="btn-azure action-btn">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>